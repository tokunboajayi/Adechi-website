        <script>
            (function () {
                var overlay = document.getElementById('page-fadein-overlay');
                if (!overlay) return;

                var delay = 0.3;
                var duration = 1.2;
                var delayMs = delay * 1000;
                var fadeMs = duration * 1000 + 50;

                function startFade() {
                    setTimeout(function () {
                        overlay.classList.add('page-fadein--fade-out');
                        setTimeout(function () {
                            overlay.remove();
                        }, fadeMs);
                    }, delayMs);
                }

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', startFade);
                } else {
                    startFade();
                }
            })();
        </script>






