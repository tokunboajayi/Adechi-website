                    let offset = 0;
                    let velocity = 0;
                    let targetVelocity = 0; // For smooth interpolation

                    function speedSeconds() {
                        const isDesktop = window.matchMedia('(min-width: 750px)').matches;
                        const s = isDesktop ? Number(root.dataset.speedDesktop || 30) : Number(root.dataset.speedMobile || 26);
                        return Math.max(1, Math.min(100, s));
