                        if (btn) {
                            if (checkoutText) {
                                btn.textContent = checkoutText;
                            }
                            if (checkoutBg) {
                                btn.style.backgroundColor = checkoutBg;
                            }
                            if (checkoutColor) {
                                btn.style.color = checkoutColor;
                            }
                            if (checkoutHoverColor) {
                                btn.addEventListener("mouseenter", function () {
                                    btn.style.color = checkoutHoverColor;
                                });
                                btn.addEventListener("mouseleave", function () {
                                    btn.style.color = checkoutColor || "";
                                });
                            }
                        }

                        /* ==========================
                           "SPECIAL CODE" LABEL
                           ========================== */

                        if (specialCodeText) {
                            var candidates = document.querySelectorAll(
                                ".cart-drawer summary, .cart-drawer button, .cart-drawer span, .cart-drawer label, .cart-drawer p, .cart-drawer h2, .cart-drawer h3"
                            );
                            candidates.forEach(function (el) {
                                var txt = (el.textContent || "").replace(/\s+/g, " ").trim();
                                if (txt === "Special Code") {
                                    el.textContent = specialCodeText;
                                }
                            });
                        }


                        /* ==========================
                           "ESTIMATED TOTAL" LABEL
                           ========================== */
                        if (estimatedLabelText) {
                            var totalCandidates = document.querySelectorAll(
                                ".cart-drawer span, .cart-drawer p, .cart-drawer strong, .cart-drawer .totals__total"
                            );
                            totalCandidates.forEach(function (el) {
                                var txt = (el.textContent || "").replace(/\s+/g, " ").trim();
                                if (txt === "Estimated total") {
                                    el.textContent = estimatedLabelText;
                                }
                            });
                        }

                        /* ==========================
                           HELPER TEXT ABOVE BUTTON
                           ========================== */
                        var checkoutButton = document.querySelector(
                            ".cart-drawer .cart__checkout-button, .cart-drawer button[name='checkout']"
                        );
                        var checkoutRow = checkoutButton ? checkoutButton.parentElement : null;
                        var existing = checkoutRow ? checkoutRow.querySelector(".doberman-cart-helper") : null;

                        if (checkoutRow) {
                            if (helperEnabled && helperText) {
                                if (!existing) {
                                    existing = document.createElement("div");
                                    existing.className = "doberman-cart-helper";
                                    checkoutRow.insertBefore(existing, checkoutRow.firstChild);
                                }
                                existing.textContent = helperText;
                                existing.style.display = "block";
                            } else if (existing) {
                                existing.textContent = "";
                                existing.style.display = "none";
                            }
                        }

                        /* ==========================
                           CART TITLE ("CART")
                           ========================== */
                        if (cartTitleText && cartTitleText.trim() !== "") {
                            var headings = document.querySelectorAll(
                                ".cart-drawer [data-cart-drawer-title], .cart-drawer h1, .cart-drawer h2, .cart-drawer h3"
                            );
                            headings.forEach(function (el) {
                                var txt = (el.textContent || "").replace(/\s+/g, " ").trim();
                                if (/^Cart\b/i.test(txt)) {
                                    el.textContent = cartTitleText;
                                }
                            });
                        }
                    } catch (e) {
                        console.error("Doberman cart drawer – labels error", e);
                    }
                }

                function initCartDrawerStyling() {
                    updateCartDrawerLabels();

                    // Don't re-attach if already done
                    if (window.__dobermanCartObserver) return;
                    if (!document.body) return;

                    var scheduled = false;
                    var observer = new MutationObserver(function () {
                        if (scheduled) return;
                        scheduled = true;
                        setTimeout(function () {
                            scheduled = false;
                            updateCartDrawerLabels();
                        }, 50);
                    });

                    observer.observe(document.body, {
                        childList: true,
                        subtree: true,
                        attributes: true
                    });

                    window.__dobermanCartObserver = observer;
                }

                // Run once DOM is ready
                if (document.readyState === "loading") {
                    document.addEventListener("DOMContentLoaded", initCartDrawerStyling);
                } else {
                    initCartDrawerStyling();
                }

                // Extra hooks for editor / theme events
                document.addEventListener("shopify:section:load", initCartDrawerStyling);
                document.addEventListener("cart:updated", initCartDrawerStyling);
            })();
        </script>




