            .product-card .variant-pills {
                width: 100%;
                align-self: flex-start;
                gap: 12px !important;
                margin-top: 0px !important;
                margin-bottom: 16px !important;

                display: flex !important;
                flex-wrap: wrap !important;

                /* NEW — alignment controller */

                justify-content: flex-start !important;
                text-align: left;

            }

            .product-card .variant-pill {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                white-space: nowrap;
                box-sizing: border-box;

                padding: 6px 8px !important;
                font-size: 12px !important;
                font-weight: 300 !important;
                line-height: 1 !important;
                border-radius: 2px !important;

                min-height: calc(12px + (6px * 2));


                background: #fcfcfc !important;



                border: 1px solid #f7f7f7 !important;


                color: #282828 !important;
                transition: background .2s ease !important;
            }

            .product-card .variant-pill:hover {
                background: #e9e9e9 !important;
            }

            .product-card .variant-pill.is-soldout {

                background: #ededed !important;



                border-color: #efefef !important;


                color: #545454 !important;
            }

            .product-card .variant-pill.is-soldout .variant-pill__label {
                text-decoration: line-through !important;
                text-decoration-thickness: 1.2px !important;
                text-decoration-color: rgba(0, 0, 0, .35) !important;
            }

            .card-wrapper .variant-pills,
            .card-wrapper .variant-pill {
                z-index: 6;
                position: relative;
            }





            /* Hard kill any leftover theme shadows/gradients */
            .product-card .variant-pill,
            .product-card .variant-pill:hover,
            .product-card .variant-pill.is-soldout {
                box-shadow: none !important;
                background-image: none !important;
            }
        </style>

        <script>
            (function () {
                function getVariantPill(event) {
                    return event.target.closest('a.variant-pill');
                }

                function blockCardHandlers(event) {
                    const pill = getVariantPill(event);
                    if (!pill) return;
                    event.stopPropagation();
                }

                function handleVariantPillClick(event) {
                    const pill = getVariantPill(event);
                    if (!pill) return;

                    const baseUrl =
                        pill.getAttribute('data-variant-url') ||
                        pill.getAttribute('href') ||
                        '';

                    const variantId = pill.getAttribute('data-variant-id');
                    if (!variantId || !baseUrl) return;

                    const cleanBase = baseUrl.split('?')[0];
                    const finalUrl = cleanBase + '?variant=' + encodeURIComponent(variantId);

                    event.preventDefault();
                    event.stopPropagation();
                    if (event.stopImmediatePropagation) event.stopImmediatePropagation();

                    window.location.href = finalUrl;
                }

                ['pointerdown', 'mousedown', 'pointerup', 'mouseup'].forEach(function (type) {
                    document.addEventListener(type, blockCardHandlers, true);
                });

                document.addEventListener('click', handleVariantPillClick, true);
            })();
        </script>


