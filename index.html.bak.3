    <script>
        function cleanQuickAddButtons(root) {
            var context = root || document;

            context.querySelectorAll('.product-card').forEach(function (card) {
                var buttons = card.querySelectorAll(
                    '.quick-add__submit, .card__quick-add, [data-add-to-cart], button[name="add"]'
                );

                if (buttons.length > 1) {
                    // Hide ONLY the first quick-add style control
                    buttons[0].style.display = 'none';
                }
            });
        }

        document.addEventListener('DOMContentLoaded', function () {
            // Initial pass
            cleanQuickAddButtons(document);

            // Watch for dynamically-added product cards (recommended, sliders, etc.)
            var observer = new MutationObserver(function (mutations) {
                mutations.forEach(function (mutation) {
                    mutation.addedNodes.forEach(function (node) {
                        if (!(node instanceof Element)) return;

                        // If a product card or a container that may contain product cards appears,
                        // re-run the cleaner on that subtree.
                        if (node.matches('.product-card') || node.querySelector('.product-card')) {
                            cleanQuickAddButtons(node);
                        }
                    });
                });
            });

            observer.observe(document.body, {
                childList: true,
                subtree: true
            });

            // Also respond to Shopify's section reloads in the editor
            document.addEventListener('shopify:section:load', function (event) {
                cleanQuickAddButtons(event.target);
            });
        });
    </script>


