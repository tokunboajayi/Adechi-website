                    const baseFrag = () => {
                        const f = document.createDocumentFragment();
                        originals.forEach(n => f.appendChild(n.cloneNode(true)));
                        return f;
                    };

                    deck.innerHTML = '';
                    for (let i = 0; i < SIDE_CYCLES; i++) deck.appendChild(baseFrag());
                    originals.forEach(n => deck.appendChild(n.cloneNode(true)));
                    for (let i = 0; i < SIDE_CYCLES; i++) deck.appendChild(baseFrag());

                    // Measure one period
                    function measurePeriod() {
                        let w = 0;
                        originals.forEach((_, i) => {
                            const clone = deck.children[SIDE_CYCLES * originals.length + i];
                            if (clone) w += clone.getBoundingClientRect().width;
                        });
                        const style = getComputedStyle(deck);
                        const gap = parseFloat(style.gap) || 0;
                        w += gap * originals.length;
                        return Math.max(1, Math.round(w));
