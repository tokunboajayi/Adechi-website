        </style>



        <script>
            window.addEventListener('DOMContentLoaded', function () {
                // Custom labels from Theme Editor
                var addText = "Place In Cart";
                var soldText = "Sold Out";

                // Theme default locale strings
                var defaultAddText = "Add to cart";
                var defaultSoldText = "Sold out";

                /* ==============================
                   Patch theme.strings
                   ============================== */
                try {
                    if (window.theme && theme.strings) {
                        var map = [
                            { value: addText, keys: ['addToCart', 'add_to_cart'] },
                            { value: soldText, keys: ['soldOut', 'sold_out'] }
                        ];

                        map.forEach(function (entry) {
                            if (!entry.value) return;
                            entry.keys.forEach(function (k) {
                                if (theme.strings.hasOwnProperty(k)) {
                                    theme.strings[k] = entry.value;
                                }
                            });
                        });
                    }
                } catch (e) {
                    console.warn('ATC Button Styler: theme.strings patch failed', e);
                }

                function normalize(str) {
                    if (!str) return '';
                    return str.replace(/\s+/g, ' ').trim();
                }

                var rules = [
                    { defaults: [defaultAddText], replacement: addText },
                    { defaults: [defaultSoldText], replacement: soldText }
                ];

                function applyToButton(btn) {
                    if (!btn) return;

                    // Visible label
                    var label =
                        btn.querySelector('.button__text') ||
                        btn.querySelector('span:not(.loading-overlay__spinner):not(.icon):not([aria-hidden="true"])') ||
                        btn;

                    var curr = normalize(label.textContent || '');

                    rules.forEach(function (rule) {
                        rule.defaults.forEach(function (def) {
                            if (curr === normalize(def)) {
                                label.textContent = rule.replacement;
                            }
                        });
                    });

                    // Update button's dataset attributes too
                    Object.keys(btn.dataset || {}).forEach(function (key) {
                        var val = btn.dataset[key];
                        if (!val) return;

                        rules.forEach(function (rule) {
                            rule.defaults.forEach(function (def) {
                                if (normalize(val) === normalize(def)) {
                                    btn.dataset[key] = rule.replacement;
                                }
                            });
                        });
                    });

                    // Tag true SOLD OUT buttons so CSS can target only them
                    var isSoldOut = normalize(label.textContent || '') === normalize(soldText);
                    if (isSoldOut) {
                        btn.dataset.soldOutButton = 'true';
                    } else {
                        // Ensure we don't accidentally style "adding" / other states
                        delete btn.dataset.soldOutButton;
                    }
                }

                function scan(root) {
                    var scope = root || document;
                    var buttons = scope.querySelectorAll(
                        'form[action*="/cart/add"] button[type="submit"],' +
                        '.product-form__submit,' +
                        '.add-to-cart-button'
                    );
                    buttons.forEach(applyToButton);
                }

                // Initial run
                scan(document);

                // Re-run on dynamic changes inside product form & cart drawer
                var observeRoots = document.querySelectorAll(
                    'form[action*="/cart/add"], .product-form, .product-form__buttons, .cart-drawer'
                );

                if (observeRoots.length) {
                    var observer = new MutationObserver(function () {
                        observeRoots.forEach(scan);
                    });

                    observeRoots.forEach(function (root) {
                        observer.observe(root, {
                            childList: true,
                            characterData: true,
                            subtree: true
                        });
                    });
                }
            });
        </script>



