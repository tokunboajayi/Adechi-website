        <script>
            document.addEventListener('DOMContentLoaded', function () {


                /* ======================================
                   2) PREFETCH QUICK ADD HTML
                   ====================================== */
                (function prefetchQuickAdd() {
                    // Grab likely quick-add triggers on Horizon
                    var triggers = document.querySelectorAll(
                        'button[name="quick-add"], button[data-product-url], .product-card__quick-add'
                    );
                    if (!triggers.length) return;

                    var seen = {};

                    triggers.forEach(function (btn) {
                        var url =
                            btn.getAttribute('data-product-url') ||
                            (btn.dataset && btn.dataset.productUrl) ||
                            btn.getAttribute('data-url');

                        if (!url) return;
                        if (seen[url]) return;
                        seen[url] = true;

                        try {
                            fetch(url, { credentials: 'same-origin' }).catch(function () { });
                        } catch (e) {
                            // fail silently – just a warmup
                        }
                    });
                })();

                /* ======================================
                   3) POPUP-ONLY ATC LABEL OVERRIDE
                      (does NOT touch product page ATC)
                   ====================================== */
                (function () {
                    var NEW_LABEL = "Place in Cart";
                    if (!NEW_LABEL) return; // nothing set in Theme Editor

                    function relabel(scope) {
                        var modalRoot =
                            (scope && scope.querySelector && scope.querySelector('quick-add-dialog .quick-add-modal')) ||
                            document.querySelector('quick-add-dialog .quick-add-modal');

                        if (!modalRoot) return;

                        var buttons = modalRoot.querySelectorAll(
                            '.product-form__submit, button[name="add"], button[type="submit"]'
                        );

                        buttons.forEach(function (btn) {
                            // Extra safety: must live inside quick-add-dialog
                            if (!btn.closest('quick-add-dialog')) return;

                            var label =
                                btn.querySelector('.button__text') ||
                                btn.querySelector(
                                    'span:not(.loading-overlay__spinner):not(.icon):not([aria-hidden="true"])'
                                ) ||
                                btn;

                            if (label) {
                                label.textContent = NEW_LABEL;
                            }
                        });
                    }

                    // Initial run (in case content is already mounted)
                    relabel();

                    // Watch the modal content container for injected quick-add markup
                    var host = document.querySelector('#quick-add-modal-content');
                    if (!host) return;

                    var observer = new MutationObserver(function (mutations) {
                        mutations.forEach(function (mutation) {
                            mutation.addedNodes.forEach(function (node) {
                                if (node.nodeType === 1) {
                                    relabel(node);
                                }
                            });
                        });
                    });

                    observer.observe(host, { childList: true, subtree: true });
                })();
            });
        </script>



