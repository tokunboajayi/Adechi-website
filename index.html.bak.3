    <div id="shopify-section-variant-pills-toggle" class="shopify-section">

        <style>
            /* =========================
     Variant Pills — Controller (px only)
     ========================= */



            /* Remove Horizon's built-in card gap so our margins are the boss */
            .product-card .card-information {
                row-gap: 0 !important;
                gap: 0 !important;
            }


            /* ===== CUSTOM STYLES ===== */

            .product-card .product-title,
