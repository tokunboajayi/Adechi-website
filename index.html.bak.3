            <script>
                (function () {
                    const section = document.getElementById('answer-call-template--19764624130136__answer_call_qWUP9Q');
                    if (!section) return;

                    const states = {
                        incoming: section.querySelector('.answer-call__state--incoming'),
                        active: section.querySelector('.answer-call__state--active'),
                        declined: section.querySelector('.answer-call__state--declined')
                    };

                    const videos = {
                        pre: section.querySelector('.answer-call__video--pre'),
                        post: section.querySelector('.answer-call__video--post'),
                        recipient: section.querySelector('.answer-call__video--recipient')
                    };

                    const pip = section.querySelector('.answer-call__pip');
                    const screen = section.querySelector('.answer-call__screen');
                    const controls = section.querySelector('.answer-call__controls');
                    const activeLabel = section.querySelector('.answer-call__active-label');
                    const activeState = section.querySelector('.answer-call__state--active');
                    const micBtn = section.querySelector('.answer-call__control-btn--mic');

                    const autoplayAudio = section.dataset.autoplayAudio === 'true';
                    const declinedDuration = parseInt(section.dataset.declinedDuration) || 3000;

                    let isMuted = !autoplayAudio;
                    let controlsVisible = true, hideControlsTimeout = null;
                    let isDragging = false, hasDragged = false, dragStartX = 0, dragStartY = 0;
                    let pipStartTop = 0, pipStartLeft = 0, pipWidth = 0, pipHeight = 0;

                    function switchState(newState) {
                        Object.keys(states).forEach(key => states[key].classList.remove('active'));
                        states[newState].classList.add('active');
                    }

                    function playVideo(video) {
                        if (video && video.tagName === 'VIDEO') video.play().catch(() => { });
                    }

                    function pauseVideo(video) {
                        if (video && video.tagName === 'VIDEO') { video.pause(); video.currentTime = 0; }
                    }

                    function toggleControls(show) {
                        controlsVisible = show;
                        if (controls) controls.classList.toggle('hidden', !show);
                        if (activeLabel) activeLabel.classList.toggle('hidden', !show);
                        if (pip) pip.classList.toggle('controls-hidden', !show);
                    }

                    function scheduleHideControls() {
                        clearTimeout(hideControlsTimeout);
                        hideControlsTimeout = setTimeout(() => toggleControls(false), 9000);
                    }

                    function acceptCall() {
                        switchState('active');
                        pauseVideo(videos.pre);
                        playVideo(videos.post);
                        playVideo(videos.recipient);

                        // Handle audio based on autoplay setting
                        if (autoplayAudio && videos.post && videos.post.tagName === 'VIDEO') {
                            videos.post.muted = false;
                            isMuted = false;
                        } else {
                            isMuted = true;
                        }
                        updateMuteState();

                        toggleControls(true);
                        scheduleHideControls();
                    }

                    function declineCall() {
                        switchState('declined');
                        pauseVideo(videos.pre);
                        setTimeout(() => resetCall(), declinedDuration);
                    }

                    function resetCall() {
                        switchState('incoming');
                        pauseVideo(videos.post);
                        pauseVideo(videos.recipient);
                        playVideo(videos.pre);
                        toggleControls(true);
                        clearTimeout(hideControlsTimeout);
                        isMuted = !autoplayAudio;
                        updateMuteState();
                        if (pip) {
                            pip.dataset.position = 'top-right';
                            pip.style.cssText = '';
                        }
                    }

                    function toggleMute() {
                        isMuted = !isMuted;
                        updateMuteState();
                    }

                    function updateMuteState() {
                        if (micBtn) micBtn.classList.toggle('muted', isMuted);
                        // Only unmute the post-pickup caller video, not the recipient
                        if (videos.post && videos.post.tagName === 'VIDEO') {
                            videos.post.muted = isMuted;
                        }
                    }

                    function getSnapPosition(x, y, screenRect) {
                        const screenCenterX = screenRect.width / 2;
                        const screenCenterY = screenRect.height / 2;
                        const relX = x - screenRect.left;
                        const relY = y - screenRect.top;
                        const isTop = relY < screenCenterY;
                        const isLeft = relX < screenCenterX;
                        if (isTop && isLeft) return 'top-left';
                        if (isTop) return 'top-right';
                        if (isLeft) return 'bottom-left';
                        return 'bottom-right';
                    }

                    function startDrag(e) {
                        if (!pip || !states.active.classList.contains('active')) return;
                        e.preventDefault();
                        isDragging = true;
                        hasDragged = false;
                        pip.classList.add('dragging');
                        pip.classList.remove('snapping');

                        const touch = e.touches ? e.touches[0] : e;
                        dragStartX = touch.clientX;
                        dragStartY = touch.clientY;

                        const pipRect = pip.getBoundingClientRect();
                        const screenRect = screen.getBoundingClientRect();
                        pipWidth = pipRect.width;
                        pipHeight = pipRect.height;
                        pipStartTop = pipRect.top - screenRect.top;
                        pipStartLeft = pipRect.left - screenRect.left;

                        pip.style.position = 'absolute';
                        pip.style.width = pipWidth + 'px';
                        pip.style.height = pipHeight + 'px';
                        pip.style.aspectRatio = 'auto';
                        pip.style.top = pipStartTop + 'px';
                        pip.style.left = pipStartLeft + 'px';
                        pip.style.right = 'auto';
                        pip.style.bottom = 'auto';
                    }

                    function onDrag(e) {
                        if (!isDragging || !pip) return;
                        e.preventDefault();
                        hasDragged = true;

                        const touch = e.touches ? e.touches[0] : e;
                        const deltaX = touch.clientX - dragStartX;
                        const deltaY = touch.clientY - dragStartY;
                        const screenRect = screen.getBoundingClientRect();

                        let newLeft = pipStartLeft + deltaX;
                        let newTop = pipStartTop + deltaY;

                        newLeft = Math.max(12, Math.min(newLeft, screenRect.width - pipWidth - 12));
                        newTop = Math.max(12, Math.min(newTop, screenRect.height - pipHeight - 12));

                        pip.style.left = newLeft + 'px';
                        pip.style.top = newTop + 'px';
                    }

                    function endDrag(e) {
                        if (!isDragging || !pip) return;
                        isDragging = false;
                        pip.classList.remove('dragging');
                        pip.classList.add('snapping');

                        const touch = e.changedTouches ? e.changedTouches[0] : e;
                        const screenRect = screen.getBoundingClientRect();
                        const snapPosition = getSnapPosition(touch.clientX, touch.clientY, screenRect);

                        pip.style.cssText = '';
                        pip.dataset.position = snapPosition;
                        setTimeout(() => pip.classList.remove('snapping'), 250);
                    }

                    if (pip) {
                        pip.addEventListener('mousedown', startDrag);
                        pip.addEventListener('touchstart', startDrag, { passive: false });
                        document.addEventListener('mousemove', onDrag);
                        document.addEventListener('touchmove', onDrag, { passive: false });
                        document.addEventListener('mouseup', endDrag);
                        document.addEventListener('touchend', endDrag);
                    }

                    if (activeState) {
                        activeState.addEventListener('mouseenter', function () {
                            if (states.active.classList.contains('active')) {
                                toggleControls(true);
                                clearTimeout(hideControlsTimeout);
                            }
                        });

                        activeState.addEventListener('mouseleave', function () {
                            if (states.active.classList.contains('active')) {
                                scheduleHideControls();
                            }
                        });
                    }

                    section.addEventListener('click', function (e) {
                        const action = e.target.closest('[data-action]')?.dataset.action;
                        if (action === 'accept') return acceptCall();
                        if (action === 'decline') return declineCall();
                        if (action === 'end') return resetCall();
                        if (action === 'toggle-mute') return toggleMute();

                        if (states.active.classList.contains('active') && !hasDragged) {
                            const clickedPip = e.target.closest('.answer-call__pip');
                            const clickedControls = e.target.closest('.answer-call__controls');
                            const clickedLabel = e.target.closest('.answer-call__active-label');
                            if (!clickedControls && !clickedLabel && !clickedPip) {
                                toggleControls(!controlsVisible);
                                if (controlsVisible) scheduleHideControls();
                            } else if (controlsVisible) {
                                clearTimeout(hideControlsTimeout);
                                scheduleHideControls();
                            }
                        }
                        hasDragged = false;
                    });

                    playVideo(videos.pre);
                })();
