        <script>
            (function () {
                function configureAndPlay(video) {
                    try {
                        if (!video || video.dataset.dobSetup === '1') return;
                        video.dataset.dobSetup = '1';

                        video.muted = true;
                        video.loop = true;
                        video.autoplay = true;
                        video.playsInline = true;
                        video.setAttribute('muted', 'muted');
                        video.setAttribute('playsinline', 'playsinline');
                        video.setAttribute('autoplay', 'autoplay');

                        // no controls at all
                        video.controls = false;
                        video.removeAttribute('controls');

                        // click video to toggle play/pause
                        video.addEventListener('click', function () {
                            try {
                                if (video.paused) {
                                    var p2 = video.play();
                                    if (p2 && typeof p2.catch === 'function') p2.catch(function () { });
                                } else {
                                    video.pause();
                                }
                            } catch (err) { }
                        });

                        var p = video.play && video.play();
                        if (p && typeof p.catch === 'function') {
                            p.catch(function () { });
                        }
                    } catch (e) { }
                }

                function initProductPageVideoAutoplay(scope) {
                    var root = scope || document;

                    var containers = root.querySelectorAll(
                        '.product-media-container--image, ' +
                        '.product-media-container--video, ' +
                        '.product-media-container--external_video, ' +
                        '.product-media-container--model'
                    );

                    containers.forEach(function (container) {
                        var deferred = container.querySelector('deferred-media, .deferred-media');

                        if (deferred) {
                            if (deferred.dataset.dobAutoplayInit === '1') return;
                            deferred.dataset.dobAutoplayInit = '1';
                            deferred.setAttribute('data-dob-autoplay', 'true');

                            var video = deferred.querySelector('video');

                            if (!video) {
                                var clickTarget =
                                    deferred.querySelector('button, .deferred-media__poster, [data-media-id]');
                                if (clickTarget) {
                                    clickTarget.click();
                                }

                                setTimeout(function () {
                                    var v2 = deferred.querySelector('video');
                                    if (v2) configureAndPlay(v2);
                                }, 400);
                            } else {
                                configureAndPlay(video);
                            }
                        } else {
                            var videos = container.querySelectorAll('video');
                            videos.forEach(configureAndPlay);
                        }
                    });
                }

                document.addEventListener('DOMContentLoaded', function () {
                    initProductPageVideoAutoplay();
                });

                document.addEventListener('shopify:section:load', function (event) {
                    initProductPageVideoAutoplay(event.target);
                });
            })();
        </script>



