            <script>
                (function () {
                    const SECTION_ID = 'template--19764624130136__video_shop_the_look_Fjcy3t';
                    const TOTAL_ORIGINAL_SLIDES = 4;
                    const DESKTOP_GAP = 4;
                    const MOBILE_GAP = 4;
                    const SLIDE_SPEED = 800;
                    const DESKTOP_INACTIVE_SCALE = 90 / 100;
                    const MOBILE_INACTIVE_SCALE = 80 / 100;

                    let swiper = null;
                    let drawerListenerAttached = false;

                    function setupDrawerToggle() {
                        const sectionEl = document.getElementById('shopify-section-' + SECTION_ID);
                        if (!sectionEl || drawerListenerAttached) return;

                        drawerListenerAttached = true;

                        // Use capture phase to ensure we get the event first
                        sectionEl.addEventListener('click', function (e) {
                            // Check if clicked on drawer toggle button or its children
                            const toggleBtn = e.target.closest('.js-drawer-toggle');

                            if (toggleBtn) {
                                e.stopPropagation();
                                e.preventDefault();

                                // Find the parent card
                                const card = toggleBtn.closest('.vstl-card-' + SECTION_ID);
                                if (!card) return;

                                // Close all other open drawers first
                                sectionEl.querySelectorAll('.vstl-card-' + SECTION_ID + '.open').forEach(c => {
                                    if (c !== card) c.classList.remove('open');
                                });

                                // Toggle this card's drawer
                                card.classList.toggle('open');
                                return;
                            }

                            // If clicked on product info link inside trigger, let it navigate
                            const productLink = e.target.closest('.vstl-product-info-' + SECTION_ID);
                            if (productLink && productLink.tagName === 'A') {
                                // Allow the link to work normally
                                return;
                            }

                            // Click outside cards closes all drawers
                            if (!e.target.closest('.vstl-card-' + SECTION_ID)) {
                                sectionEl.querySelectorAll('.vstl-card-' + SECTION_ID + '.open').forEach(card => {
                                    card.classList.remove('open');
                                });
                            }
                        }, true); // Use capture phase
                    }

                    function initSwiper() {
                        const swiperEl = document.getElementById('swiper-' + SECTION_ID);
                        const sectionEl = document.getElementById('shopify-section-' + SECTION_ID);

                        if (!swiperEl || TOTAL_ORIGINAL_SLIDES === 0) return;

                        const isMobile = window.innerWidth <= 768;
                        const baseGap = isMobile ? MOBILE_GAP : DESKTOP_GAP;
                        const scale = isMobile ? MOBILE_INACTIVE_SCALE : DESKTOP_INACTIVE_SCALE;

                        // Get actual slide width in pixels
                        const firstSlide = swiperEl.querySelector('.swiper-slide');
                        const slideWidth = firstSlide ? firstSlide.offsetWidth : 300;

                        // When inactive slide is scaled, it creates empty space on each side
                        // Empty space per side = (1 - scale) * slideWidth / 2
                        const scaleOffset = (1 - scale) * slideWidth / 2;

                        // The adjusted gap accounts for the visual space created by scaling
                        const adjustedGap = baseGap - scaleOffset;

                        // Destroy previous instance if exists
                        if (swiper) {
                            swiper.destroy(true, true);
                        }

                        // Start at the middle set (beginning of 2nd set)
                        const startIndex = TOTAL_ORIGINAL_SLIDES;

                        swiper = new Swiper(swiperEl, {
                            slidesPerView: 'auto',
                            centeredSlides: true,
                            loop: false,
                            initialSlide: startIndex,
                            spaceBetween: adjustedGap,
                            speed: SLIDE_SPEED,
                            grabCursor: true,
                            watchSlidesProgress: true,
                            slideToClickedSlide: true,

                            updateOnWindowResize: true,
                            resizeObserver: true,
                            observer: true,
                            observeParents: true,

                            navigation: {
                                nextEl: '#vstl-next-' + SECTION_ID,
                                prevEl: '#vstl-prev-' + SECTION_ID,
                            },


                            autoplay: {
                                delay: 9500,
                                disableOnInteraction: false,
                                pauseOnMouseEnter: true
                            },


                            on: {
                                init: function () {
                                    setTimeout(() => {
                                        this.update();
                                    }, 100);
                                },
                                slideChange: function () {
                                    // Close all drawers when slide changes
                                    if (sectionEl) {
                                        sectionEl.querySelectorAll('.vstl-card-' + SECTION_ID + '.open').forEach(card => {
                                            card.classList.remove('open');
                                        });
                                    }
                                },
                                transitionEnd: function () {
                                    const currentIndex = this.activeIndex;

                                    if (currentIndex < TOTAL_ORIGINAL_SLIDES) {
                                        this.slideTo(currentIndex + TOTAL_ORIGINAL_SLIDES, 0, false);
                                    } else if (currentIndex >= TOTAL_ORIGINAL_SLIDES * 2) {
                                        this.slideTo(currentIndex - TOTAL_ORIGINAL_SLIDES, 0, false);
                                    }
                                }
                            }
                        });

                        // Setup drawer toggle (only once)
                        setupDrawerToggle();

                        window['vstlSwiper_' + SECTION_ID] = swiper;
                    }

                    // Init after a brief delay to ensure DOM is ready and slides have width
                    if (document.readyState === 'loading') {
                        document.addEventListener('DOMContentLoaded', function () {
                            setTimeout(initSwiper, 50);
                        });
                    } else {
                        setTimeout(initSwiper, 50);
                    }

                    // Handle resize
                    let resizeTimeout;
                    window.addEventListener('resize', function () {
                        clearTimeout(resizeTimeout);
                        resizeTimeout = setTimeout(initSwiper, 150);
                    });

                    // Shopify editor - reset listener flag on section reload
                    document.addEventListener('shopify:section:load', function (e) {
                        if (e.target.id === 'shopify-section-' + SECTION_ID) {
                            drawerListenerAttached = false;
                            setTimeout(initSwiper, 100);
                        }
                    });
                })();
            </script>


